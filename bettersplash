    # Ejecucion directa para que si muestre las salidas de tus programas en pantalla
    config_path = os.path.expanduser('~/.config/bettersplash.conf')
    if os.path.exists(config_path):
        with open(config_path, 'r') as f:
            commands = [line.strip() for line in f.readlines() if line.strip()]
        for cmd in commands:
            if cmd and cmd not in ["Not set", "No configurado"]:
