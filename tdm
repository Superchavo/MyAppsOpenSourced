    # --- Custom DE functions ---
    def open_custom_de_window(self):
        if self.is_locked:
            messagebox.showwarning("Locked!", f"Wait {self.get_wait_time_str()} before trying.")
            return
            
        top = tk.Toplevel(self.root)
        top.title("Add Custom Desktop")
        top.transient(self.root)
        top.overrideredirect(True)
        tw, th = 480, 280
        tx = (self.sw // 2) - (tw // 2)
        ty = (self.sh // 2) - (th // 2)
        top.geometry(f"{tw}x{th}+{tx}+{ty}")
        top.focus_set()
        top.grab_set()
        top.configure(bg="#0a1a2a")
        
        container = tk.Frame(top, bg="#0a1a2a", bd=2, highlightbackground="#2a3a5a", highlightthickness=1)
        container.pack(fill="both", expand=True, padx=15, pady=15)
        
        tk.Label(container, text="Add Desktop Environment", font=("Segoe UI", 14, "bold"), 
                fg="#5ac8fa", bg="#0a1a2a").pack(pady=(10, 15))
        
        tk.Label(container, text="Name:", font=("Segoe UI", 9, "bold"), 
                fg="#ffffff", bg="#0a1a2a").pack(anchor="w")
        entry_name = tk.Entry(container, font=("Segoe UI", 10), bg="#0a1a2a", fg="#ffffff", 
                             insertbackground="#5ac8fa", bd=1, highlightbackground="#2a3a5a")
        entry_name.pack(fill="x", pady=(0, 10))
        entry_name.focus_set()
        
        tk.Label(container, text="Command:", font=("Segoe UI", 9, "bold"), 
                fg="#ffffff", bg="#0a1a2a").pack(anchor="w")
        entry_cmd = tk.Entry(container, font=("Segoe UI", 10), bg="#0a1a2a", fg="#ffffff", 
                            insertbackground="#5ac8fa", bd=1, highlightbackground="#2a3a5a")
        entry_cmd.pack(fill="x", pady=(0, 15))
        
        def submit():
            de_name = entry_name.get().strip()
            de_cmd = entry_cmd.get().strip()
            if not de_name or not de_cmd:
                messagebox.showwarning("Hold up!", "Both fields are required.", parent=container)
                return
            if de_name in self.all_sessions:
                messagebox.showwarning("Oops!", "That DE already exists.", parent=container)
                return
                
            os.makedirs(CONFIG_DIR, exist_ok=True)
            custom_data = {}
            if os.path.exists(CUSTOM_SESSIONS_PATH):
                try:
                    with open(CUSTOM_SESSIONS_PATH, "r") as f: custom_data = json.load(f)
                except: pass
            
            custom_data[de_name] = de_cmd
            with open(CUSTOM_SESSIONS_PATH, "w") as f:
                json.dump(custom_data, f, indent=4)
                
            try:
                with open(CONFIG_PATH, "r") as f: config_data = json.load(f)
            except: config_data = {"session_order": []}
                
            if "session_order" not in config_data: config_data["session_order"] = []
            config_data["session_order"].insert(0, de_name)
            for s in self.all_sessions.keys():
                if s not in config_data["session_order"]: config_data["session_order"].append(s)
                    
            with open(CONFIG_PATH, "w") as f: json.dump(config_data, f, indent=4)

            self.all_sessions[de_name] = de_cmd
            self.listbox.insert(0, de_name)
            self.listbox.select_set(0)
            self.session_name_label.config(text=de_name)
            self.update_login_button()
            messagebox.showinfo("Awesome!", f"'{de_name}' added!", parent=container)
            top.destroy()
            
        def cancel(): top.destroy()

        btn_frame = tk.Frame(container, bg="#0a1a2a")
        btn_frame.pack(fill="x", pady=10)
        tk.Button(btn_frame, text="Add", font=("Segoe UI", 10, "bold"),
                 bg="#1a6a8a", fg="#ffffff", activebackground="#2a7a9a",
                 bd=0, width=10, command=submit).pack(side="left", padx=5)
        tk.Button(btn_frame, text="Cancel", font=("Segoe UI", 10, "bold"),
                 bg="#4a1a1a", fg="#ffffff", activebackground="#5a2a2a",
                 bd=0, width=10, command=cancel).pack(side="right", padx=5)

    def delete_selected_de(self):
        if self.is_locked:
            messagebox.showwarning("Locked!", f"Wait {self.get_wait_time_str()} before trying.")
            return
            
        try:
            selected_idx = self.listbox.curselection()[0]
            selected_name = self.listbox.get(selected_idx)
        except IndexError:
            messagebox.showwarning("Hey!", "Select a DE first.")
            return

        is_native = False
        if os.path.exists(XSESSIONS_DIR):
            for f in os.listdir(XSESSIONS_DIR):
                if f.endswith(".desktop"):
                    try:
                        with open(os.path.join(XSESSIONS_DIR, f), "r") as file:
                            for line in file:
                                if line.startswith("Name=") and line.replace("Name=", "").strip() == selected_name:
                                    is_native = True
                                    break
                    except: pass
                if is_native: break

        if is_native:
            messagebox.showerror("Nope!", f"'{selected_name}' is a system DE.")
            return

        confirm = messagebox.askyesno("Sure?", f"Delete '{selected_name}'?")
        if not confirm: return

        if selected_name in self.all_sessions: del self.all_sessions[selected_name]

        if os.path.exists(CUSTOM_SESSIONS_PATH):
            try:
                with open(CUSTOM_SESSIONS_PATH, "r") as f: custom_json = json.load(f)
                if selected_name in custom_json: del custom_json[selected_name]
                with open(CUSTOM_SESSIONS_PATH, "w") as f: json.dump(custom_json, f, indent=4)
            except: pass

        data = {"session_order": []}
        try:
            if os.path.exists(CONFIG_PATH):
                with open(CONFIG_PATH, "r") as f: data = json.load(f)
        except: pass

        if "session_order" in data and selected_name in data["session_order"]: data["session_order"].remove(selected_name)
        try:
            with open(CONFIG_PATH, "w") as f: json.dump(data, f, indent=4)
        except: pass

        try:
            self.listbox.delete(selected_idx)
            if self.listbox.size() > 0:
                self.listbox.select_set(0)
                self.session_name_label.config(text=self.listbox.get(0))
            else:
                self.session_name_label.config(text="None")
            self.update_login_button()
        except: pass

    def save_current_order(self):
        items = list(self.listbox.get(0, tk.END))
        os.makedirs(CONFIG_DIR, exist_ok=True)
        try:
            with open(CONFIG_PATH, "w") as f: json.dump({"session_order": items}, f, indent=4)
        except: pass

    def load_saved_order(self, detected_list):
        os.makedirs(CONFIG_DIR, exist_ok=True)
        if not os.path.exists(CONFIG_PATH):
            try:
                with open(CONFIG_PATH, "w") as f: json.dump({"session_order": detected_list}, f, indent=4)
            except: pass
            return detected_list

        try:
            with open(CONFIG_PATH, "r") as f:
                data = json.load(f)
                saved_order = data.get("session_order", [])
        except: 
            return detected_list
            
        ordered_list = []
        for item in saved_order:
            if item in detected_list and item not in ordered_list:
                ordered_list.append(item)
        for item in detected_list:
            if item not in ordered_list:
                ordered_list.append(item)
        return ordered_list

    # --- Animations ---
    def animate_entry(self):
        moved = False
        if self.current_y > self.target_y:
            distance = self.current_y - self.target_y
            self.current_y -= max(1, int(distance * 0.15))
            self.card.place(x=self.target_x, y=self.current_y)
            moved = True
        if self.alpha < 1.0:
            self.alpha += 0.06
            self.root.attributes("-alpha", min(1.0, self.alpha))
            moved = True
        if moved: self.root.after(33, self.animate_entry)

    def animate_exit(self):
        self.fade_out_loop()

    def fade_out_loop(self):
        if self.alpha > 0.0:
            self.alpha -= 0.12
            self.root.attributes("-alpha", max(0.0, self.alpha))
            self.current_y -= 10
            self.card.place(x=self.target_x, y=self.current_y)
            self.root.after(33, self.fade_out_loop)
        else: 
            self.launch_session()

    # Removed animate_card_glow (no gradient)

    # --- Session Detection ---
    def detect_xsessions(self):
        found = {}
        
        if os.path.exists(XSESSIONS_DIR):
            for file in os.listdir(XSESSIONS_DIR):
                if file.endswith(".desktop"):
                    try:
                        with open(os.path.join(XSESSIONS_DIR, file), "r") as f:
                            name, exec_cmd = "", ""
                            for line in f:
                                if line.startswith("Name="): 
                                    name = line.replace("Name=", "").strip()
                                elif line.startswith("Exec="): 
                                    exec_cmd = line.replace("Exec=", "").replace("%U", "").replace("%F", "").replace("%u", "").replace("%f", "").strip()
                            if name and exec_cmd: 
                                found[name] = exec_cmd
                    except: pass
        
        if os.path.exists(CUSTOM_SESSIONS_PATH):
            try:
                with open(CUSTOM_SESSIONS_PATH, "r") as f:
                    custom_sessions = json.load(f)
                    for custom_name, custom_cmd in custom_sessions.items():
                        found[custom_name] = custom_cmd
            except: pass

        if not found:
            found["KDE Plasma (X11)"] = "startplasma-x11"
            found["XFCE"] = "startxfce4"
            found["MATE"] = "mate-session"
            found["Openbox"] = "openbox-session"
            found["LXQt (X11)"] = "startlxqt"
            found["IceWM"] = "icewm"
        
        return found

    # --- Launch Session ---
    def launch_session(self):
        try: 
            selected_name = self.listbox.get(self.listbox.curselection()[0]).strip()
        except: 
            selected_name = list(self.all_sessions.keys())[0]
            
        exec_string = self.all_sessions.get(selected_name, 'startplasma-x11')
        display_var = os.environ.get("DISPLAY", ":1")
        
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(RUN_SCRIPT_PATH, "w") as f:
            f.write("#!/bin/bash\n")
            f.write(f"export DISPLAY={display_var}\n")
            f.write(f"echo '--- TDM SESSION INITIALIZATION ---' > {LOG_PATH}\n")
            f.write(f"echo 'Selected: {selected_name}' >> {LOG_PATH}\n")
            f.write(f"echo 'Command: {exec_string}' >> {LOG_PATH}\n")
            f.write("pkill -f kwin 2>/dev/null\n")
            f.write("pkill -f plasmashell 2>/dev/null\n")
            f.write("pkill -f xfce4-session 2>/dev/null\n")
            f.write("pkill -f openbox 2>/dev/null\n")
            f.write("pkill -f fluxbox 2>/dev/null\n")
            f.write("pkill -f mate-session 2>/dev/null\n")
            f.write("pkill -f icewm 2>/dev/null\n")
            f.write(f"eval \"{exec_string}\" >> {LOG_PATH} 2>&1\n")
            
        os.chmod(RUN_SCRIPT_PATH, 0o755)
        self.chosen_command = RUN_SCRIPT_PATH
        
        self.root.destroy()
        self.root.quit()

        print("\033[1;32mTDM has closed\033[0m")

# --- Entry Point ---
if __name__ == "__main__":
    try:
        root = tk.Tk()
        app = TermuxDM(root)
        root.mainloop()
        
        if hasattr(app, 'chosen_command') and app.chosen_command:
            os.system("clear")
            print("\033[1;36m[*] Starting your session...\033[0m")
            print(f"\033[1;33m[*] Check {LOG_PATH} if something goes wrong.\033[0m")
            os.system(app.chosen_command)
        else:
            print("\033[1;32mTDM has closed\033[0m")
    except KeyboardInterrupt:
        print("\n\033[1;33mTDM closed by user\033[0m")
        sys.exit(0)
    except Exception as e:
        crash_handler(type(e), e, e.__traceback__)
