    def update_clock(self):
        now = datetime.now().strftime("%I:%M %p")
        self.clock_label.config(text=now)
        self.root.after(10000, self.update_clock)

    def load_random_wallpaper(self):
        dirs = ["/data/data/com.termux/files/usr/share/wallpapers", 
                "/data/data/com.termux/files/usr/share/backgrounds"]
        images = []
        for d in dirs:
            if os.path.exists(d):
                for root, _, files in os.walk(d):
                    for f in files:
                        if f.lower().endswith(('.png', '.jpg', '.jpeg')):
                            images.append(os.path.join(root, f))
        if not images:
            return
        try:
            img = Image.open(random.choice(images))
            img = img.resize((self.sw, self.sh), Image.Resampling.LANCZOS)
            from PIL import ImageDraw
            overlay = Image.new('RGBA', img.size, (0,0,0,0))
            draw = ImageDraw.Draw(overlay)
            draw.rectangle([(0,0), (self.sw,self.sh)], fill=(10, 14, 26, 80))
            img = img.convert('RGBA')
            img = Image.alpha_composite(img, overlay)
            self.bg_image = ImageTk.PhotoImage(img)
            self.canvas = tk.Canvas(self.root, width=self.sw, height=self.sh, highlightthickness=0)
            self.canvas.place(x=0, y=0)
            self.canvas.create_image(0, 0, image=self.bg_image, anchor="nw")
        except:
            pass

    def change_wallpaper(self):
        self.load_random_wallpaper()

    # --- Password functions ---
    def get_stored_password(self):
        if os.path.exists(PASSWD_FILE):
            try:
                with open(PASSWD_FILE, 'r') as f:
                    config = json.load(f)
                    return config.get("password", "")
            except:
                pass
        return None

    def get_wait_time_str(self):
        idx = min(self.password_attempts - 1, len(WAIT_TIMES) - 1)
        wt = WAIT_TIMES[idx]
        if wt >= 60:
            m = wt // 60
            return f"{m} minute{'s' if m > 1 else ''}"
        return f"{wt} seconds"

    def start_lock_timer(self):
        self.is_locked = True
        self.login_btn.config(state="disabled")
        self.pass_entry.config(state="disabled")
        
        idx = min(self.password_attempts - 1, len(WAIT_TIMES) - 1)
        self.remaining_time = WAIT_TIMES[idx]
        
        self.pass_status.config(text="[LOCKED] Wait " + self.get_wait_time_str(), fg="#ff4d4d")
        self.pass_entry.config(fg="#ff4d4d")
        self.update_lock_timer()

    def update_lock_timer(self):
        if self.remaining_time > 0:
            m = self.remaining_time // 60
            s = self.remaining_time % 60
            t = f"{m}m {s}s" if m > 0 else f"{s}s"
            self.pass_status.config(text=f"[LOCKED] {t} remaining", fg="#ff4d4d")
            self.remaining_time -= 1
            self.root.after(1000, self.update_lock_timer)
        else:
            self.is_locked = False
            self.login_btn.config(state="normal")
            self.pass_entry.config(state="normal")
            self.pass_entry.delete(0, tk.END)
            self.pass_status.config(text="Enter password", fg="#8a9ba8")
            self.pass_entry.config(fg="#ffffff")
            self.password_attempts = 0

    def check_password_and_login(self):
        if self.is_locked:
            messagebox.showwarning("Locked!", f"Wait {self.get_wait_time_str()} before trying.")
            return
        
        stored = self.get_stored_password()
        
        if not stored:
            if not self.password_warning_shown:
                result = messagebox.askyesno(
                    "Security Warning",
                    "[!] No password is set for TDM!\n\n"
                    "This is a security risk.\n\n"
                    "Continue anyway?\n\n"
                    "(Set password with: tdmpasswd)"
                )
                self.password_warning_shown = True
                if not result:
                    return
            
            self.pass_status.config(text="[+] Logging in...", fg="#ffcc00")
            self.login_btn.config(text="See you soon!", bg="#6a3a8a")
            self.root.after(300, self.animate_exit)
            return
        
        pwd = self.pass_entry.get()
        
        if pwd == stored:
            self.password_attempts = 0
            self.pass_status.config(text="[+] Correct!", fg="#5ac8fa")
            self.login_btn.config(text="See you soon!", bg="#6a3a8a")
            self.root.after(300, self.animate_exit)
        else:
            self.password_attempts += 1
            self.pass_entry.config(fg="#ff4d4d")
            self.pass_entry.delete(0, tk.END)
            
            if self.password_attempts >= MAX_ATTEMPTS:
                self.pass_status.config(text="[X] System locked permanently!", fg="#ff0000")
                self.login_btn.config(state="disabled")
                self.pass_entry.config(state="disabled")
                messagebox.showerror("Permanently Locked!", 
                    "Too many failed attempts.\nSystem permanently locked.\nRestart TDM to try again.")
                return
            
            self.pass_status.config(
                text=f"[X] Wrong! Attempt {self.password_attempts}/{MAX_ATTEMPTS}. Locking for {self.get_wait_time_str()}", 
                fg="#ff4d4d"
            )
            self.start_lock_timer()

    def on_password_change(self, event):
        if self.is_locked:
            return
            
        pwd = self.pass_entry.get()
        stored = self.get_stored_password()
        
        if not stored:
            self.pass_status.config(text="[!] No password set", fg="#ffcc00")
            return
        
        if len(pwd) > 0:
            if pwd != stored:
                self.pass_entry.config(show="•", fg="#ff4d4d")
                self.pass_status.config(text="[X] Incorrect", fg="#ff4d4d")
            else:
                self.pass_entry.config(fg="#5ac8fa")
                self.pass_status.config(text="[+] Correct! Click Log In", fg="#5ac8fa")
        else:
            self.pass_entry.config(fg="#ffffff")
            self.pass_status.config(text="Enter password", fg="#8a9ba8")

    def show_session_menu(self, event=None):
        """Show session selection menu when gear icon is clicked"""
        menu = tk.Menu(self.root, tearoff=0, bg="#0a1a2a", fg="#ffffff", 
                       activebackground="#2a5a7a", activeforeground="#ffffff",
                       font=("Segoe UI", 10))
        
        for name in self.session_names:
            menu.add_command(label=name, command=lambda n=name: self.select_session(n))
        
        menu.add_separator()
        menu.add_command(label="[+] Add Custom DE", command=self.open_custom_de_window)
        menu.add_command(label="[X] Delete Custom DE", command=self.delete_selected_de)
        
        try:
            menu.tk_popup(event.x_root, event.y_root)
        except:
            pass

    def select_session(self, name):
        """Select a session from the menu"""
        for i in range(self.listbox.size()):
            if self.listbox.get(i).strip() == name:
                self.listbox.select_clear(0, tk.END)
                self.listbox.select_set(i)
                self.listbox.see(i)
                self.update_login_button()
                break

    def update_login_button(self, event=None):
        try:
            idx = self.listbox.curselection()[0]
            de_name = self.listbox.get(idx).strip()
            self.login_btn.config(text=f"Log In → {de_name}")
        except:
            self.login_btn.config(text="Log In")

