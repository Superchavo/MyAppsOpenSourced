# --- Crash handler ---
def crash_handler(exc_type, exc_value, exc_tb):
    if "TclError" in str(exc_type) and "display" in str(exc_value):
        print("\033[1;33m[!] Cannot connect to display. Make sure VNC is running.\033[0m")
        print("\033[1;33m[!] Try: vncserver :1\033[0m")
        sys.exit(1)
    
    error_msg = "TDM Crashed Unexpectedly\n\n"
    error_msg += f"Error: {exc_type.__name__}: {exc_value}\n\n"
    error_msg += "Traceback:\n" + "".join(traceback.format_tb(exc_tb))
    
    with open("/data/data/com.termux/files/home/.tdm-crash.log", "w") as f:
        f.write(error_msg)
    
    print("\033[1;31m" + "="*60)
    print("TDM CRASHED UNEXPECTEDLY")
    print("="*60)
    print(error_msg)
    print("="*60)
    print("\033[1;33mCrash log saved to: ~/.tdm-crash.log")
    print("\033[0m")
    sys.exit(1)

sys.excepthook = crash_handler

