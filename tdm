# --- Find active display ---
def find_active_display():
    if os.environ.get("DISPLAY"):
        display = os.environ["DISPLAY"]
        try:
            import tkinter
            test = tkinter.Tk()
            test.withdraw()
            test.destroy()
            return display
        except:
            pass
    
    for d in [":1", ":0", ":2", ":3"]:
        try:
            os.environ["DISPLAY"] = d
            import tkinter
            test = tkinter.Tk()
            test.withdraw()
            test.destroy()
            print(f"\033[1;32m[+] Found active display: {d}\033[0m")
            return d
        except:
            continue
    
    print("\033[1;31m[!] No active display found!\033[0m")
    print("\033[1;33m[!] Make sure VNC is running: vncserver :1\033[0m")
    sys.exit(1)

display = find_active_display()
os.environ["DISPLAY"] = display

